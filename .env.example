# Copy to .env (gitignored) and fill in. The app reads these from the environment.

# OCR backend: "medgemma" (local, default) or "claude" (cloud)
OCR_PROVIDER=medgemma

# Required only when OCR_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# Required only for the local MedGemma path (gated model download)
# HF_TOKEN=hf_...

# Override the URL encoded in the scan QR code (use when a tunnel like
# cloudflared/ngrok is needed because the phone can't reach the laptop's LAN IP)
# PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com
